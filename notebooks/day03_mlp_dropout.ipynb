    "def demonstrate_dropout():\n",
    "    \"\"\"演示Dropout效果\"\"\"\n",
    "    # 创建两个模型：一个有Dropout，一个没有\n",
    "    model_with_dropout = StockMLP(input_size=10, hidden_sizes=[32, 16], dropout_rate=0.5)\n",
    "    model_without_dropout = StockMLP(input_size=10, hidden_sizes=[32, 16], dropout_rate=0.0)\n",
    "    \n",
    "    # 设置为训练模式\n",
    "    model_with_dropout.train()\n",
    "    model_without_dropout.train()\n",
    "    \n",
    "    # 相同的输入\n",
    "    test_input = torch.randn(100, 10)\n",
    "    \n",
    "    print(\"训练模式下的输出变化（Dropout激活）:\")\n",
    "    outputs_dropout = []\n",
    "    outputs_no_dropout = []\n",
    "    \n",
    "    for i in range(5):\n",
    "        output_dropout = model_with_dropout(test_input)\n",
    "        output_no_dropout = model_without_dropout(test_input)\n",
    "        \n",
    "        outputs_dropout.append(output_dropout.mean().item())\n",
    "        outputs_no_dropout.append(output_no_dropout.mean().item())\n",
    "    \n",
    "    print(f\"有Dropout: {outputs_dropout}\")\n",
    "    print(f\"无Dropout: {outputs_no_dropout}\")\n",
    "    \n",
    "    # 设置为评估模式\n",
    "    model_with_dropout.eval()\n",
    "    model_without_dropout.eval()\n",
    "    \n",
    "    print(\"\\n评估模式下的输出变化（Dropout关闭）:\")\n",
    "    eval_outputs_dropout = []\n",
    "    eval_outputs_no_dropout = []\n",
    "    \n",
    "    for i in range(5):\n",
    "        output_dropout = model_with_dropout(test_input)\n",
    "        output_no_dropout = model_without_dropout(test_input)\n",
    "        \n",
    "        eval_outputs_dropout.append(output_dropout.mean().item())\n",
    "        eval_outputs_no_dropout.append(output_no_dropout.mean().item())\n",
    "    \n",
    "    print(f\"有Dropout: {eval_outputs_dropout}\")\n",
    "    print(f\"无Dropout: {eval_outputs_no_dropout}\")\n",
    "    \n",
    "    # 可视化\n",
    "    plt.figure(figsize=(12, 5))\n",
    "    \n",
    "    plt.subplot(1, 2, 1)\n",
    "    plt.plot(outputs_dropout, 'o-', label='有Dropout', color='red')\n",
    "    plt.plot(outputs_no_dropout, 's-', label='无Dropout', color='blue')\n",
    "    plt.xlabel('前向传播次数')\n",
    "    plt.ylabel('输出均值')\n",
    "    plt.title('训练模式 - Dropout随机性')\n",
    "    plt.legend()\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.subplot(1, 2, 2)\n",
    "    plt.plot(eval_outputs_dropout, 'o-', label='有Dropout', color='red')\n",
    "    plt.plot(eval_outputs_no_dropout, 's-', label='无Dropout', color='blue')\n",
    "    plt.xlabel('前向传播次数')\n",
    "    plt.ylabel('输出均值')\n",
    "    plt.title('评估模式 - Dropout关闭')\n",
    "    plt.legend()\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "demonstrate_dropout()"
   ]
